# ─── REQUIRED IN PRODUCTION (Vercel) ──────────────────────────────────

# Admin login credentials — used by /api/admin/login
ADMIN_USERNAME=michael
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign admin session tokens (HMAC-SHA256).
# Generate with:  openssl rand -hex 32
ADMIN_SECRET=replace-with-a-64-char-hex-string

# ─── STORAGE (pick ONE: MongoDB Atlas OR Vercel KV) ───────────────────

# Option A: MongoDB Atlas (free tier: https://www.mongodb.com/cloud/atlas)
# If set, all admin content edits (products, business info, theme, SEO)
# persist to MongoDB instead of the local file.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/michael-lamidis?retryWrites=true&w=majority

# ─── FILE UPLOADS (required on Vercel — local FS is read-only) ────────

# Vercel Blob token — admin image uploads will save here instead of /public/uploads.
# Create at: Vercel dashboard → your project → Storage → Create Blob store.
# BLOB_READ_WRITE_TOKEN=

# ─── OPTIONAL ─────────────────────────────────────────────────────────

# If you wire up Resend for the contact / lead forms:
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=info@michaellamidis.com.cy

# ─── CANONICAL DOMAIN ─────────────────────────────────────────────────
# The public origin used for canonical URLs, sitemap, robots and OG tags.
# Defaults to https://www.michaellamidisshop.com if unset. To switch the
# brand to the Cyprus domain, set this AND add the domain in Vercel:
# NEXT_PUBLIC_SITE_URL=https://michaellamidis.com.cy

# ─── ANALYTICS (client tags — safe to expose; gated, load only if set) ─
# Google Tag Manager container (preferred — manages GA4 inside it):
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# GA4 measurement id (loaded directly only if no GTM id is set):
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Microsoft Clarity project id:
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ─── ADMIN ANALYTICS DASHBOARD (server-only GA4 Data API) ─────────────
# Set all three to show LIVE numbers in /admin/analytics (else sample data).
# Create a Google Cloud service account, grant it Viewer on the GA4 property.
# GA4_PROPERTY_ID=123456789
# GA4_CLIENT_EMAIL=analytics-reader@your-project.iam.gserviceaccount.com
# GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
